{{ 'page-customer.css' | asset_url | stylesheet_tag }}

<div class="auth-page">
  <div class="auth-split">

    <!-- Form Panel -->
    <div class="auth-split__form">
      <div class="auth-form-inner">

        <!-- Logo -->
        <a href="{{ routes.root_url }}" class="auth-form__logo">
          {%- if section.settings.logo != blank -%}
            <img
              src="{{ section.settings.logo | img_url: '240x80' }}"
              alt="{{ shop.name | escape }}"
              width="120" height="40"
              loading="eager">
          {%- else -%}
            <span style="font-family:var(--font-heading);font-size:var(--text-xl);color:var(--color-primary);">
              {{ shop.name }}
            </span>
          {%- endif -%}
        </a>

        <p class="auth-form__eyebrow">{{ section.settings.eyebrow }}</p>
        <h1 class="auth-form__title">{{ section.settings.heading }}</h1>
        <p class="auth-form__subtitle">{{ section.settings.subheading }}</p>

        <!-- Benefits List -->
        {%- assign benefit_labels = section.settings.benefits | split: "|" -%}
        {%- if benefit_labels.size > 0 and section.settings.benefits != blank -%}
          <div class="auth-benefits">
            {%- for benefit in benefit_labels -%}
              <div class="auth-benefit">
                <span class="auth-benefit__icon">✦</span>
                <span>{{ benefit | strip }}</span>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <!-- Block-based benefits (Theme Editor) -->
        {%- for block in section.blocks -%}
          {%- if block.type == 'benefit' -%}
            {%- unless forloop.first and benefit_labels.size > 0 -%}
              <div class="auth-benefit" {{ block.shopify_attributes }}>
                <span class="auth-benefit__icon">{{ block.settings.icon }}</span>
                <span>{{ block.settings.label }}</span>
              </div>
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}

        <!-- Register Form -->
        {%- form 'create_customer', id: 'create-customer-form' -%}

          {%- if form.errors -%}
            <div class="auth-form__errors" role="alert">
              <ul>
                {%- for error in form.errors -%}
                  <li>{{ form.errors.messages[error] }}</li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          <div class="form-field__row">
            <div class="form-field">
              <label for="reg-first-name">First Name</label>
              <input
                type="text"
                id="reg-first-name"
                name="customer[first_name]"
                autocomplete="given-name"
                required
                placeholder="Priya">
            </div>
            <div class="form-field">
              <label for="reg-last-name">Last Name</label>
              <input
                type="text"
                id="reg-last-name"
                name="customer[last_name]"
                autocomplete="family-name"
                placeholder="Sharma">
            </div>
          </div>

          <div class="form-field">
            <label for="reg-email">Email Address</label>
            <input
              type="email"
              id="reg-email"
              name="customer[email]"
              autocomplete="email"
              required
              placeholder="you@example.com"
              {%- if form.errors contains 'email' -%} aria-invalid="true" {%- endif -%}>
          </div>

          <div class="form-field form-field--password">
            <label for="reg-password">Password</label>
            <input
              type="password"
              id="reg-password"
              name="customer[password]"
              autocomplete="new-password"
              required
              minlength="5"
              placeholder="Min. 5 characters"
              {%- if form.errors contains 'password' -%} aria-invalid="true" {%- endif -%}>
            <button type="button" class="form-field__toggle js-toggle-password" aria-label="Show password" data-target="reg-password">
              Show
            </button>
          </div>

          <div class="form-field form-field--password">
            <label for="reg-password-confirm">Confirm Password</label>
            <input
              type="password"
              id="reg-password-confirm"
              name="customer[password_confirmation]"
              autocomplete="new-password"
              required
              placeholder="Repeat password">
            <button type="button" class="form-field__toggle js-toggle-password" aria-label="Show password" data-target="reg-password-confirm">
              Show
            </button>
          </div>

          {%- if section.settings.show_consent_checkbox -%}
            <div class="form-field" style="flex-direction:row;align-items:flex-start;gap:var(--space-3);">
              <input type="checkbox" id="reg-consent" name="customer[accepts_marketing]" value="1"
                     style="width:auto;margin-top:3px;flex-shrink:0;">
              <label for="reg-consent" style="font-weight:400;font-size:var(--text-sm);color:var(--color-text-secondary);">
                {{ section.settings.consent_text }}
              </label>
            </div>
          {%- endif -%}

          <div class="auth-form__submit">
            <button type="submit" class="btn btn-primary btn-lg" style="width:100%;">
              Create My Account
            </button>
          </div>

          <p style="font-size:var(--text-xs);color:var(--color-text-secondary);text-align:center;margin-top:var(--space-4);">
            By creating an account, you agree to our
            <a href="/policies/privacy-policy" style="color:var(--color-primary);">Privacy Policy</a>
            and <a href="/policies/terms-of-service" style="color:var(--color-primary);">Terms of Service</a>.
          </p>

        {%- endform -%}

        <div class="auth-form__divider">
          <span>Already have an account?</span>
        </div>
        <a href="{{ routes.account_login_url }}" class="btn btn-ghost" style="width:100%;text-align:center;">
          Sign In
        </a>

        <div style="text-align:center;margin-top:var(--space-6);">
          <a href="{{ routes.root_url }}" style="color:var(--color-text-secondary);font-size:var(--text-sm);">
            ← Continue Shopping
          </a>
        </div>

      </div>
    </div>

    <!-- Visual Panel -->
    <div class="auth-split__visual">
      {%- if section.settings.background_image != blank -%}
        <img
          src="{{ section.settings.background_image | img_url: '900x1200', crop: 'center' }}"
          alt=""
          width="900" height="1200"
          loading="lazy"
          aria-hidden="true">
      {%- endif -%}
      <div class="auth-split__visual-overlay"></div>
      <div class="auth-split__visual-content">
        {%- if section.settings.visual_heading != blank -%}
          <p class="auth-split__visual-quote">{{ section.settings.visual_heading }}</p>
          <cite class="auth-split__visual-cite">{{ section.settings.visual_subtext }}</cite>
        {%- endif -%}
        <div class="auth-split__visual-badges" style="margin-top:var(--space-6);">
          {%- for block in section.blocks -%}
            {%- if block.type == 'trust_badge' -%}
              <span class="auth-split__visual-badge" {{ block.shopify_attributes }}>
                {{ block.settings.label }}
              </span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

  </div>
</div>

<script>
(function () {
  document.querySelectorAll('.js-toggle-password').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var inp = document.getElementById(btn.dataset.target);
      var isHidden = inp.type === 'password';
      inp.type = isHidden ? 'text' : 'password';
      btn.textContent = isHidden ? 'Hide' : 'Show';
    });
  });
})();
</script>

{% schema %}
{
  "name": "Customer Register",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (dark)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "✦ JOIN THE FAMILY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Create Your Kayakalp Account"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Join 2 lakh+ Indian families on their Ayurvedic wellness journey."
    },
    {
      "type": "textarea",
      "id": "benefits",
      "label": "Benefits list (pipe-separated)",
      "default": "Track your orders & reorder easily|Earn wellness points on every purchase|Get personalised Ayurvedic recommendations|Access exclusive member-only offers"
    },
    {
      "type": "checkbox",
      "id": "show_consent_checkbox",
      "label": "Show marketing consent checkbox",
      "default": true
    },
    {
      "type": "text",
      "id": "consent_text",
      "label": "Consent checkbox label",
      "default": "Send me Ayurvedic wellness tips and exclusive offers via email."
    },
    {
      "type": "header",
      "content": "Visual Panel"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "visual_heading",
      "label": "Visual panel quote",
      "default": "स्वस्थस्य स्वास्थ्य रक्षणम् — Protect the health of the healthy."
    },
    {
      "type": "text",
      "id": "visual_subtext",
      "label": "Visual panel attribution",
      "default": "— Ashtanga Hridayam"
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Visual Badge",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Badge text",
          "default": "Free Delivery ₹699+"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Register",
      "blocks": [
        { "type": "trust_badge", "settings": { "label": "🚚 Free Delivery ₹699+" } },
        { "type": "trust_badge", "settings": { "label": "🔄 Easy Returns" } },
        { "type": "trust_badge", "settings": { "label": "💵 COD Available" } }
      ]
    }
  ]
}
{% endschema %}
