{{ 'section-about.css' | asset_url | stylesheet_tag }}

<section class="section brand-story-teaser section-parchment">
  <div class="container">
    <div class="brand-story-teaser__inner">
      <div class="brand-story-teaser__content" data-animate>
        {%- if section.settings.eyebrow != blank -%}
          <p class="section-eyebrow">✦ {{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="section-title section-title--story">{{ section.settings.heading }}</h2>

        {%- if section.settings.para_1 != blank -%}
          <p class="brand-story-teaser__para">{{ section.settings.para_1 }}</p>
        {%- endif -%}
        {%- if section.settings.para_2 != blank -%}
          <p class="brand-story-teaser__para">{{ section.settings.para_2 }}</p>
        {%- endif -%}
        {%- if section.settings.para_3 != blank -%}
          <p class="brand-story-teaser__para">{{ section.settings.para_3 }}</p>
        {%- endif -%}

        <a href="{{ section.settings.cta_url | default: '/pages/our-story' }}" class="btn-arrow brand-story-teaser__cta" style="color:var(--color-primary);">
          {{ section.settings.cta_label | default: 'Read Our Story' }}
        </a>
      </div>

      {%- if section.settings.pullquote != blank -%}
        <blockquote class="brand-story-teaser__pullquote" data-animate data-animate-delay="2">
          <p>{{ section.settings.pullquote }}</p>
          {%- if section.settings.pullquote_author != blank -%}
            <cite>— {{ section.settings.pullquote_author }}</cite>
          {%- endif -%}
        </blockquote>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story Teaser",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "OUR STORY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Rooted in Tradition. Built for Today."
    },
    {
      "type": "textarea",
      "id": "para_1",
      "label": "Paragraph 1",
      "default": "Kayakalp was born from a simple belief: that India's ancient healing wisdom is not a relic of the past, but the medicine of the future."
    },
    {
      "type": "textarea",
      "id": "para_2",
      "label": "Paragraph 2",
      "default": "Our founders, rooted in a family of Ayurvedic Vaidyas from Rajasthan, grew up watching herbs heal what medicines couldn't. They set out to bring that wisdom to every Indian home."
    },
    {
      "type": "textarea",
      "id": "para_3",
      "label": "Paragraph 3",
      "default": "Today, we source directly from Himalayan herb farms, formulate using classical texts, and validate every product in NABL-certified labs. Because trust is earned, not claimed."
    },
    {
      "type": "textarea",
      "id": "pullquote",
      "label": "Pull quote (right-aligned gold text)",
      "default": "Kayakalp is not a product. It is a promise — to bring back the age-old art of healing in every Indian home."
    },
    {
      "type": "text",
      "id": "pullquote_author",
      "label": "Pull quote author",
      "default": "Founder, Kayakalp Ayurveda"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Read Our Full Story"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [
    {
      "name": "Brand Story Teaser"
    }
  ]
}
{% endschema %}
