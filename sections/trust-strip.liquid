{{ 'section-trust.css' | asset_url | stylesheet_tag }}

<div class="trust-strip">
  <div class="container">
    <div class="trust-strip__grid">
      {%- for block in section.blocks -%}
        <div
          class="trust-strip__item{% if block.settings.highlight %} trust-strip__item--highlight{% endif %}"
          data-animate
          data-animate-delay="{{ forloop.index }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="trust-strip__item-link">
          {%- endif -%}

          <span class="trust-strip__icon" aria-hidden="true">{{ block.settings.icon }}</span>
          <div class="trust-strip__text">
            <strong class="trust-strip__label">{{ block.settings.label }}</strong>
            {%- if block.settings.sublabel != blank -%}
              <small class="trust-strip__sublabel">{{ block.settings.sublabel }}</small>
            {%- endif -%}
          </div>

          {%- if block.settings.link != blank -%}
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust Strip",
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or SVG)",
          "default": "🌿"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "100% Natural"
        },
        {
          "type": "text",
          "id": "sublabel",
          "label": "Sub-label",
          "default": "No harmful chemicals"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "checkbox",
          "id": "highlight",
          "label": "Highlight (shimmer effect)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Strip",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "🌿", "label": "100% Natural", "sublabel": "No harmful chemicals" } },
        { "type": "trust_item", "settings": { "icon": "📜", "label": "AYUSH Licensed", "sublabel": "Govt. of India certified" } },
        { "type": "trust_item", "settings": { "icon": "🏆", "label": "GMP Certified", "sublabel": "Quality guaranteed", "highlight": true } },
        { "type": "trust_item", "settings": { "icon": "⭐", "label": "4.8/5 Rating", "sublabel": "2 Lakh+ happy families", "highlight": true } },
        { "type": "trust_item", "settings": { "icon": "🚚", "label": "Free Delivery ₹699+", "sublabel": "Pan India shipping" } }
      ]
    }
  ]
}
{% endschema %}
