<section class="section blog-preview section-herb">
  <div class="container">
    <div class="section-header" data-animate>
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-eyebrow">✦ {{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.heading }}</h2>
    </div>

    {%- if section.settings.blog != blank -%}
      {%- assign blog_handle = section.settings.blog -%}
      {%- assign featured_blog = blogs[blog_handle] -%}
      <div class="blog-grid" role="list">
        {%- for article in featured_blog.articles limit: section.settings.articles_count -%}
          <article class="blog-card" role="listitem" data-animate data-animate-delay="{{ forloop.index }}">
            {%- if article.image -%}
              <a href="{{ article.url }}" class="blog-card__image-wrap" tabindex="-1" aria-hidden="true">
                <img
                  class="blog-card__image"
                  src="{{ article.image | img_url: '600x400', crop: 'center' }}"
                  alt="{{ article.image.alt | default: article.title | escape }}"
                  loading="lazy"
                  width="600" height="400">
              </a>
            {%- endif -%}
            <div class="blog-card__body">
              <span class="badge badge--category blog-card__category">{{ article.tags | first | default: 'Wellness' }}</span>
              <h3 class="blog-card__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h3>
              <p class="blog-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
              <div class="blog-card__footer">
                <span class="blog-card__read-time">{{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read</span>
                <a href="{{ article.url }}" class="btn-arrow blog-card__link">Read More</a>
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- elsif section.blocks.size > 0 -%}
      <div class="blog-grid" role="list">
        {%- for block in section.blocks -%}
          <article class="blog-card" role="listitem" data-animate data-animate-delay="{{ forloop.index }}" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <a href="{{ block.settings.url }}" class="blog-card__image-wrap" tabindex="-1" aria-hidden="true">
                <img
                  class="blog-card__image"
                  src="{{ block.settings.image | img_url: '600x400', crop: 'center' }}"
                  alt="{{ block.settings.title | escape }}"
                  loading="lazy" width="600" height="400">
              </a>
            {%- endif -%}
            <div class="blog-card__body">
              <span class="badge badge--category blog-card__category">{{ block.settings.category | default: 'Wellness' }}</span>
              <h3 class="blog-card__title"><a href="{{ block.settings.url }}">{{ block.settings.title }}</a></h3>
              <p class="blog-card__excerpt">{{ block.settings.excerpt }}</p>
              <div class="blog-card__footer">
                <span class="blog-card__read-time">{{ block.settings.read_time | default: '3 min read' }}</span>
                <a href="{{ block.settings.url }}" class="btn-arrow blog-card__link">Read More</a>
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <div class="text-center" style="margin-top:var(--space-10);" data-animate>
        <a href="{{ section.settings.cta_url | default: '/blogs/health-tips' }}" class="btn btn-secondary">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
.blog-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-6);
}
@media (min-width: 640px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1024px) { .blog-grid { grid-template-columns: repeat(3, 1fr); } }

.blog-card {
  background: var(--color-bg-primary);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  transition: transform var(--transition-organic), box-shadow var(--transition-organic);
}
.blog-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
}
.blog-card__image-wrap {
  display: block;
  overflow: hidden;
  aspect-ratio: 3/2;
}
.blog-card__image {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform var(--transition-slow);
}
.blog-card:hover .blog-card__image { transform: scale(1.05); }
.blog-card__body {
  padding: var(--space-6);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  flex: 1;
}
.blog-card__category { align-self: flex-start; }
.blog-card__title {
  font-family: var(--font-heading);
  font-size: var(--text-md);
  line-height: var(--leading-snug);
  margin: 0;
}
.blog-card__title a { color: var(--color-text-primary); transition: color var(--transition-fast); }
.blog-card__title a:hover { color: var(--color-primary); }
.blog-card__excerpt {
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  line-height: var(--leading-relaxed);
}
.blog-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: var(--space-3);
  border-top: 1px solid var(--color-border-light);
}
.blog-card__read-time {
  font-family: var(--font-label);
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
}
</style>

{% schema %}
{
  "name": "Blog Preview",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "FROM OUR VAIDYAS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Wisdom from Our Vaidyas"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "articles_count",
      "label": "Number of articles",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "View All Articles"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Article",
      "limit": 6,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "5 Ayurvedic Herbs for Hair Growth" },
        { "type": "text", "id": "category", "label": "Category", "default": "HAIR CARE" },
        { "type": "textarea", "id": "excerpt", "label": "Excerpt", "default": "Discover the classical formulations that Ayurvedic Vaidyas have used for centuries to restore hair health." },
        { "type": "url", "id": "url", "label": "Article URL" },
        { "type": "text", "id": "read_time", "label": "Read time", "default": "4 min read" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blog Preview"
    }
  ]
}
{% endschema %}
