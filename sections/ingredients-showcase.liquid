{{ 'section-ingredients.css' | asset_url | stylesheet_tag }}

<section class="section ingredients-showcase" data-animate>
  <div class="container">
    <div class="section-header" data-animate>
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-eyebrow">✦ {{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="section-subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="ingredients-grid" role="list">
      {%- for block in section.blocks -%}
        <article
          class="herb-card"
          role="listitem"
          data-animate
          data-animate-delay="{{ forloop.index | modulo: 5 | plus: 1 }}"
          {{ block.shopify_attributes }}
        >
          <div class="herb-card__image-wrap">
            {%- if block.settings.image != blank -%}
              <img
                class="herb-card__image"
                src="{{ block.settings.image | img_url: '500x500', crop: 'center' }}"
                srcset="{{ block.settings.image | img_url: '300x300', crop: 'center' }} 300w,
                        {{ block.settings.image | img_url: '500x500', crop: 'center' }} 500w"
                sizes="(max-width: 640px) 45vw, (max-width: 1024px) 30vw, 20vw"
                alt="{{ block.settings.name_english | escape }}"
                loading="lazy"
                width="500" height="500">
            {%- else -%}
              <div class="herb-card__image-placeholder" aria-hidden="true"></div>
            {%- endif -%}

            <div class="herb-card__overlay" aria-hidden="true">
              {%- if block.settings.benefit != blank -%}
                <p class="herb-card__overlay-text">{{ block.settings.benefit }}</p>
              {%- endif -%}
              {%- if block.settings.dosha != blank -%}
                <span class="herb-card__dosha-pill herb-card__dosha-pill--{{ block.settings.dosha | downcase }}">
                  {{ block.settings.dosha }}
                </span>
              {%- endif -%}
              {%- if block.settings.classical_reference != blank -%}
                <p class="herb-card__reference">{{ block.settings.classical_reference }}</p>
              {%- endif -%}
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="herb-card__overlay-link">Learn more →</a>
              {%- endif -%}
            </div>
          </div>

          <div class="herb-card__body">
            {%- if block.settings.name_sanskrit != blank -%}
              <p class="herb-card__name-sanskrit">{{ block.settings.name_sanskrit }}</p>
            {%- endif -%}
            <h3 class="herb-card__name-english">{{ block.settings.name_english }}</h3>
          </div>
        </article>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="text-center" style="margin-top:var(--space-10);" data-animate>
        <a href="{{ section.settings.cta_url | default: '/pages/ingredients' }}" class="btn btn-secondary">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Ingredients Showcase",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "NATURE'S PHARMACY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pure Ingredients. Ancient Science."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every formula begins with a single root, leaf, or seed — sourced with intention, prepared with care."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Explore All Ingredients"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "blocks": [
    {
      "type": "herb",
      "name": "Herb",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Herb image"
        },
        {
          "type": "text",
          "id": "name_sanskrit",
          "label": "Sanskrit / Hindi name",
          "default": "अश्वगंधा"
        },
        {
          "type": "text",
          "id": "name_english",
          "label": "English name",
          "default": "Ashwagandha"
        },
        {
          "type": "text",
          "id": "benefit",
          "label": "One-line benefit (shown on hover)",
          "default": "The ancient adaptogen for strength and resilience"
        },
        {
          "type": "text",
          "id": "classical_reference",
          "label": "Classical reference (shown on hover)",
          "default": "Mentioned in Charaka Samhita, 600 BCE"
        },
        {
          "type": "select",
          "id": "dosha",
          "label": "Dosha",
          "options": [
            { "value": "Vata", "label": "Vata" },
            { "value": "Pitta", "label": "Pitta" },
            { "value": "Kapha", "label": "Kapha" },
            { "value": "Tridosha", "label": "Tridosha (all)" }
          ],
          "default": "Vata"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Learn more link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingredients Showcase",
      "blocks": [
        {
