            "classical_reference": "Charaka Samhita, 600 BCE",
            "dosha": "Vata"
          }
        },
        {
          "type": "herb",
          "settings": {
            "name_sanskrit": "शतावरी",
            "name_english": "Shatavari",
            "benefit": "Queen of herbs — supports hormonal balance and deep rejuvenation",
            "classical_reference": "Sushruta Samhita, 400 BCE",
            "dosha": "Vata"
          }
        },
        {
          "type": "herb",
          "settings": {
            "name_sanskrit": "मेथी",
            "name_english": "Methi (Fenugreek)",
            "benefit": "Golden seeds for blood sugar balance and metabolic health",
            "classical_reference": "Ashtanga Hridayam, 600 CE",
            "dosha": "Kapha"
          }
        },
        {
          "type": "herb",
          "settings": {
            "name_sanskrit": "गिलोय",
            "name_english": "Giloy",
