{{ 'section-products.css' | asset_url | stylesheet_tag }}

<section class="section featured-products" data-animate>
  <div class="container">
    <div class="section-header" data-animate>
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-eyebrow">✦ {{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="section-subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- assign card_themes = 'noir,maroon,lavender' | split: ',' -%}

    {%- if section.settings.collection != blank -%}
      {%- assign featured_collection = collections[section.settings.collection] -%}
      {%- assign products_limit = section.settings.products_to_show | default: 8 -%}

      <div class="featured-products__grid" role="list">
        {%- for product in featured_collection.products limit: products_limit -%}
          {%- assign theme_index = forloop.index0 | modulo: 3 -%}
          {%- assign card_theme = card_themes[theme_index] -%}
          <div role="listitem" data-animate data-animate-delay="{{ forloop.index | modulo: 4 | plus: 1 }}">
            {% render 'product-card', product: product, lazy: true, card_theme: card_theme %}
          </div>
        {%- else -%}
          {%- for i in (1..8) -%}
            <div role="listitem" class="product-card product-card--skeleton" aria-hidden="true">
              <div class="product-card__image-wrap"></div>
              <div class="product-card__body">
                <p class="product-card__name">Loading...</p>
                <p class="product-card__price-sale">₹---</p>
              </div>
            </div>
          {%- endfor -%}
        {%- endfor -%}
      </div>

    {%- elsif section.blocks.size > 0 -%}
      <div class="featured-products__grid" role="list">
        {%- for block in section.blocks -%}
          {%- if block.settings.product != blank -%}
            {%- assign p = all_products[block.settings.product] -%}
            {%- assign theme_index = forloop.index0 | modulo: 3 -%}
            {%- assign card_theme = card_themes[theme_index] -%}
            <div role="listitem" data-animate data-animate-delay="{{ forloop.index | modulo: 4 | plus: 1 }}" {{ block.shopify_attributes }}>
              {% render 'product-card', product: p, lazy: true, card_theme: card_theme %}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
      <div class="featured-products__cta" data-animate>
        <a href="{{ section.settings.cta_url }}" class="btn btn-secondary">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "MOST LOVED"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Most Loved Formulas"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Crafted from classical texts. Proven in modern homes."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection (auto-fills from here)"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 12,
      "step": 2,
      "default": 8
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "View All Products"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button URL"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 12,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "settings": {
        "heading": "Our Most Loved Formulas",
        "subheading": "Crafted from classical texts. Proven in modern homes."
      }
    }
  ]
}
{% endschema %}
