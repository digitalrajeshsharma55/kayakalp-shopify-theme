{{ 'section-trust.css' | asset_url | stylesheet_tag }}

<section class="section testimonials section-parchment">
  <div class="container">
    <div class="section-header" data-animate>
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-eyebrow">✦ {{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="section-subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="testimonials-grid" role="list">
      {%- for block in section.blocks -%}
        <blockquote
          class="testimonial-card"
          role="listitem"
          data-animate
          data-animate-delay="{{ forloop.index | modulo: 3 | plus: 1 }}"
          {{ block.shopify_attributes }}
        >
          <div class="testimonial-card__header">
            <div class="testimonial-card__avatar-wrap">
              {%- if block.settings.photo != blank -%}
                <img
                  class="testimonial-card__avatar"
                  src="{{ block.settings.photo | img_url: '100x100', crop: 'center' }}"
                  alt="{{ block.settings.name | escape }}"
                  loading="lazy"
                  width="60" height="60">
              {%- else -%}
                <div class="testimonial-card__avatar-placeholder" aria-hidden="true">
                  {{ block.settings.name | slice: 0 | upcase }}
                </div>
              {%- endif -%}
            </div>
            <div class="testimonial-card__meta">
              <div class="testimonial-card__stars" aria-label="5 stars">★★★★★</div>
              <cite class="testimonial-card__name">{{ block.settings.name }}</cite>
              <p class="testimonial-card__location">
                {{ block.settings.city }}
                {%- if block.settings.product != blank -%}
                  <span class="testimonial-card__product">· {{ block.settings.product }}</span>
                {%- endif -%}
              </p>
            </div>
            {%- if block.settings.verified -%}
              <span class="badge badge--verified testimonial-card__verified">✓ Verified</span>
            {%- endif -%}
          </div>

          <p class="testimonial-card__quote">{{ block.settings.quote }}</p>
        </blockquote>
      {%- endfor -%}
    </div>

    <!-- Overall rating summary -->
    {%- if section.settings.show_summary -%}
      <div class="testimonials-summary" data-animate>
        <div class="testimonials-summary__stars" aria-label="4.8 out of 5 stars">★★★★★</div>
        <p class="testimonials-summary__text">{{ section.settings.summary_text | default: '4.8/5 based on 12,400+ verified reviews' }}</p>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
.testimonials-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-6);
}
@media (min-width: 640px) { .testimonials-grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1024px) { .testimonials-grid { grid-template-columns: repeat(3, 1fr); } }

.testimonial-card {
  background: var(--color-bg-primary);
  border-radius: var(--radius-xl);
  padding: var(--space-6);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border-light);
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  transition: transform var(--transition-organic), box-shadow var(--transition-organic);
  margin: 0;
}
.testimonial-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
}
.testimonial-card__header {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  flex-wrap: wrap;
}
.testimonial-card__avatar-wrap { flex-shrink: 0; }
.testimonial-card__avatar {
  width: 56px; height: 56px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid var(--color-border-light);
}
.testimonial-card__avatar-placeholder {
  width: 56px; height: 56px;
  border-radius: 50%;
  background: var(--color-bg-herb);
  border: 2px solid var(--color-border-light);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-heading);
  font-size: var(--text-lg);
  color: var(--color-primary);
}
.testimonial-card__meta { flex: 1; }
.testimonial-card__stars { color: var(--color-accent-gold); font-size: var(--text-sm); letter-spacing: 1px; }
.testimonial-card__name {
  display: block;
  font-family: var(--font-label); font-weight: 700; font-size: var(--text-sm);
  color: var(--color-text-primary); font-style: normal;
}
.testimonial-card__location {
  font-size: var(--text-xs); color: var(--color-text-secondary);
  margin-top: var(--space-1);
}
.testimonial-card__product {
  color: var(--color-primary); font-weight: 600;
}
.testimonial-card__verified {
  margin-left: auto; align-self: flex-start; flex-shrink: 0;
  font-size: 0.65rem; padding: 2px 8px;
}
.testimonial-card__quote {
  font-family: var(--font-subheading);
  font-size: var(--text-md);
  font-style: italic;
  color: var(--color-text-primary);
  line-height: var(--leading-relaxed);
  position: relative;
  padding-left: var(--space-6);
}
.testimonial-card__quote::before {
  content: '"';
  position: absolute;
  left: 0; top: -4px;
  font-size: 3rem;
  color: var(--color-accent-gold);
  opacity: 0.3;
  font-family: var(--font-heading);
  line-height: 1;
}
.testimonials-summary {
  text-align: center; margin-top: var(--space-12);
}
.testimonials-summary__stars { color: var(--color-accent-gold); font-size: var(--text-2xl); letter-spacing: 2px; }
.testimonials-summary__text { font-family: var(--font-label); font-size: var(--text-sm); color: var(--color-text-secondary); margin-top: var(--space-2); }
</style>

