{{ 'page-customer.css' | asset_url | stylesheet_tag }}

<div class="auth-page">
  <div class="auth-split">

    <!-- Form Panel -->
    <div class="auth-split__form">
      <div class="auth-form-inner">

        <!-- Logo -->
        <a href="{{ routes.root_url }}" class="auth-form__logo">
          {%- if section.settings.logo != blank -%}
            <img
              src="{{ section.settings.logo | img_url: '240x80' }}"
              alt="{{ shop.name | escape }}"
              width="120" height="40"
              loading="eager">
          {%- else -%}
            <span style="font-family:var(--font-heading);font-size:var(--text-xl);color:var(--color-primary);">
              {{ shop.name }}
            </span>
          {%- endif -%}
        </a>

        <p class="auth-form__eyebrow">{{ section.settings.eyebrow }}</p>
        <h1 class="auth-form__title">{{ section.settings.heading }}</h1>
        <p class="auth-form__subtitle">{{ section.settings.subheading }}</p>

        <!-- Login Form -->
        {%- form 'customer_login', id: 'customer-login-form' -%}

          {%- if form.errors -%}
            <div class="auth-form__errors" role="alert">
              <ul>
                {%- for error in form.errors -%}
                  <li>{{ form.errors.messages[error] }}</li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          <div class="form-field">
            <label for="login-email">Email Address</label>
            <input
              type="email"
              id="login-email"
              name="customer[email]"
              autocomplete="email"
              required
              placeholder="you@example.com"
              {%- if form.errors contains 'email' -%} aria-invalid="true" {%- endif -%}>
          </div>

          <div class="form-field form-field--password">
            <label for="login-password">Password</label>
            <input
              type="password"
              id="login-password"
              name="customer[password]"
              autocomplete="current-password"
              required
              placeholder="Your password">
            <button type="button" class="form-field__toggle js-toggle-password" aria-label="Show password" data-target="login-password">
              Show
            </button>
          </div>

          <div class="auth-form__forgot">
            <a href="#recover" id="forgot-link" aria-controls="recover-form">Forgot password?</a>
          </div>

          <div class="auth-form__submit">
            <button type="submit" class="btn btn-primary btn-lg" style="width:100%;">
              Sign In to Account
            </button>
          </div>

        {%- endform -%}

        <!-- Password Recovery Form (hidden by default) -->
        <div id="recover-form" style="display:none;" aria-hidden="true">
          <div class="auth-form__divider" style="margin-top:var(--space-8);">
            <span>Reset Password</span>
          </div>

          {%- form 'recover_customer_password', id: 'customer-recover-form' -%}

            {%- if form.posted_successfully? -%}
              <div class="auth-form__success" role="status">
                ✅ Check your email — we've sent reset instructions to your inbox.
              </div>
            {%- endif -%}

            {%- if form.errors -%}
              <div class="auth-form__errors" role="alert">
                <ul>
                  {%- for error in form.errors -%}
                    <li>{{ form.errors.messages[error] }}</li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}

            <div class="form-field">
              <label for="recover-email">Your Email Address</label>
              <input
                type="email"
                id="recover-email"
                name="email"
                autocomplete="email"
                required
                placeholder="you@example.com">
            </div>

            <button type="submit" class="btn btn-secondary" style="width:100%;">
              Send Reset Link
            </button>

            <div style="text-align:center;margin-top:var(--space-4);">
              <a href="#" class="js-cancel-recover" style="font-family:var(--font-label);font-size:var(--text-sm);color:var(--color-text-secondary);">
                ← Back to Sign In
              </a>
            </div>

          {%- endform -%}
        </div>

        {%- if section.settings.show_register_link -%}
          <div class="auth-form__divider">
            <span>New to Kayakalp?</span>
          </div>
          <a href="{{ routes.account_register_url }}" class="btn btn-ghost" style="width:100%;text-align:center;">
            Create an Account
          </a>
        {%- endif -%}

        <div class="auth-form__switch" style="margin-top:var(--space-6);">
          <a href="{{ routes.root_url }}" style="color:var(--color-text-secondary);font-size:var(--text-sm);">
            ← Continue Shopping
          </a>
        </div>
      </div>
    </div>

    <!-- Visual Panel -->
    <div class="auth-split__visual">
      {%- if section.settings.background_image != blank -%}
        <img
          src="{{ section.settings.background_image | img_url: '900x1200', crop: 'center' }}"
          alt=""
          width="900" height="1200"
          loading="lazy"
          aria-hidden="true">
      {%- endif -%}
      <div class="auth-split__visual-overlay"></div>
      <div class="auth-split__visual-content">
        {%- if section.settings.quote != blank -%}
          <p class="auth-split__visual-quote">{{ section.settings.quote }}</p>
          <cite class="auth-split__visual-cite">{{ section.settings.quote_author }}</cite>
        {%- endif -%}
        <div class="auth-split__visual-badges">
          {%- for block in section.blocks -%}
            {%- if block.type == 'trust_badge' -%}
              <span class="auth-split__visual-badge" {{ block.shopify_attributes }}>
                {{ block.settings.label }}
              </span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

  </div>
</div>

<script>
(function () {
  /* Show/hide password toggle */
  document.querySelectorAll('.js-toggle-password').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var inp = document.getElementById(btn.dataset.target);
      var isHidden = inp.type === 'password';
      inp.type = isHidden ? 'text' : 'password';
      btn.textContent = isHidden ? 'Hide' : 'Show';
    });
  });

  /* Forgot password accordion */
  var loginForm = document.getElementById('customer-login-form');
  var recoverForm = document.getElementById('recover-form');
  var forgotLink = document.getElementById('forgot-link');
  var cancelLink = document.querySelector('.js-cancel-recover');

  if (forgotLink && recoverForm && loginForm) {
    forgotLink.addEventListener('click', function (e) {
      e.preventDefault();
      loginForm.style.display = 'none';
      recoverForm.style.display = 'block';
      recoverForm.setAttribute('aria-hidden', 'false');
    });
  }
  if (cancelLink) {
    cancelLink.addEventListener('click', function (e) {
      e.preventDefault();
      recoverForm.style.display = 'none';
      recoverForm.setAttribute('aria-hidden', 'true');
      loginForm.style.display = 'block';
    });
  }

  /* Auto-open recover form if posted successfully */
  {%- if recover.form.posted_successfully? -%}
  if (recoverForm) {
    loginForm.style.display = 'none';
    recoverForm.style.display = 'block';
  }
  {%- endif -%}
})();
</script>

{% schema %}
{
  "name": "Customer Login",
  "tag": null,
  "class": "customer-login-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (dark variant)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "✦ WELCOME BACK"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading",
      "default": "Sign In to Your Account"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Access your order history, saved addresses, and Ayurvedic wellness journey."
    },
    {
      "type": "checkbox",
      "id": "show_register_link",
      "label": "Show 'Create Account' link",
      "default": true
    },
    {
      "type": "header",
      "content": "Visual Panel (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "quote",
      "label": "Inspirational quote",
      "default": "आरोग्यं परमं भाग्यं — Health is the greatest wealth."
    },
    {
      "type": "text",
      "id": "quote_author",
      "label": "Quote attribution",
      "default": "— Charaka Samhita"
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Badge text",
          "default": "AYUSH Licensed"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Login",
      "blocks": [
        { "type": "trust_badge", "settings": { "label": "📜 AYUSH Licensed" } },
        { "type": "trust_badge", "settings": { "label": "🏆 GMP Certified" } },
        { "type": "trust_badge", "settings": { "label": "2L+ Happy Families" } }
      ]
    }
  ]
}
{% endschema %}
