{{ 'section-trust.css' | asset_url | stylesheet_tag }}

<section class="section section-why-kayakalp" data-animate>
  <div class="container">

    <div class="section-header" data-animate>
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-eyebrow">✦ {{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="section-subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <!-- Three Trust Pillars -->
    <div class="trust-pillars">
      {%- for block in section.blocks -%}
        {%- if block.type == 'pillar' -%}
          <div
            class="trust-pillar"
            data-animate
            data-animate-delay="{{ forloop.index }}"
            {{ block.shopify_attributes }}
          >
            <div class="trust-pillar__image-wrap">
              {%- if block.settings.image != blank -%}
                <img
                  class="trust-pillar__image"
                  src="{{ block.settings.image | img_url: '800x600', crop: 'center' }}"
                  srcset="{{ block.settings.image | img_url: '500x375', crop: 'center' }} 500w,
                          {{ block.settings.image | img_url: '800x600', crop: 'center' }} 800w"
                  sizes="(max-width: 767px) 100vw, 33vw"
                  alt="{{ block.settings.title | escape }}"
                  loading="lazy"
                  width="800" height="600">
              {%- else -%}
                <div class="trust-pillar__image-placeholder" aria-hidden="true"></div>
              {%- endif -%}
              <span class="trust-pillar__num" aria-hidden="true">{{ block.settings.number | default: '01' }}</span>
            </div>

            <div class="trust-pillar__body">
              {%- if block.settings.category_label != blank -%}
                <p class="trust-pillar__category">{{ block.settings.category_label }}</p>
              {%- endif -%}
              <h3 class="trust-pillar__title">{{ block.settings.title }}</h3>
              {%- if block.settings.description != blank -%}
                <p class="trust-pillar__desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Stats + Certifications -->
    <div class="trust-bottom" data-animate>
      <div class="trust-stats">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="trust-stat" {{ block.shopify_attributes }}>
              <span class="trust-stat__number">{{ block.settings.number }}</span>
              <span class="trust-stat__label">{{ block.settings.label }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="trust-certs">
        <span class="trust-cert-badge">AYUSH Ministry Certified</span>
        <span class="trust-cert-badge">GMP Compliant Facility</span>
        <span class="trust-cert-badge">NABL Accredited Testing</span>
        <span class="trust-cert-badge">ISO 9001:2015</span>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Why Kayakalp",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "WHY 2 LAKH+ FAMILIES TRUST US"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ancient Wisdom. Modern Standards."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "From Himalayan farms to AYUSH-certified labs — every step of the Kayakalp promise."
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Trust Pillar",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Pillar image"
        },
        {
          "type": "text",
          "id": "number",
          "label": "Display number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "category_label",
          "label": "Category label",
          "default": "PURE SOURCING"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Farm-to-Formula"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "We source directly from organic Himalayan farms — no intermediaries, no compromises. Herbs harvested at peak potency, at altitude."
        }
      ]
    },
    {
      "type": "stat",
      "name": "Statistic",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "2L+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Happy Families"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Kayakalp",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "number": "01",
            "category_label": "PURE SOURCING",
            "title": "Farm-to-Formula",
            "description": "We source directly from organic Himalayan farms — no intermediaries, no compromises. Herbs harvested at peak potency, at altitude."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "number": "02",
            "category_label": "CLASSICAL KNOWLEDGE",
            "title": "Rooted in Ancient Texts",
            "description": "Every formula is drawn from Charaka Samhita, Ashtanga Hridayam, and Sushruta Samhita — reviewed by 40+ practising Vaidyas."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "number": "03",
            "category_label": "MODERN STANDARDS",
            "title": "AYUSH Certified. GMP Compliant.",
            "description": "Formulated in our NABL-tested, GMP-compliant facility. Every batch tested for purity, potency, and safety before it reaches you."
          }
        },
        { "type": "stat", "settings": { "number": "2L+", "label": "Happy Families" } },
        { "type": "stat", "settings": { "number": "40+", "label": "Ayurvedic Vaidyas" } },
        { "type": "stat", "settings": { "number": "50+", "label": "Formulas" } },
        { "type": "stat", "settings": { "number": "10+", "label": "Years of Research" } }
      ]
    }
  ]
}
{% endschema %}
