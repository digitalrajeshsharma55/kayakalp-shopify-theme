        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "YouTube URL"
      },
      {
        "type": "text",
        "id": "social_twitter_link",
        "label": "Twitter/X URL"
      }
    ]
  },
  {
    "name": "SEO",
    "settings": [
      {
        "type": "image_picker",
        "id": "og_image_fallback",
        "label": "Default social sharing image"
