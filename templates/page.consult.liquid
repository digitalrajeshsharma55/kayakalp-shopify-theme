<!-- Consult a Vaidya Page -->

<!-- Hero -->
<section class="section section-dark consult-hero" style="min-height:50vh;display:flex;align-items:center;text-align:center;">
  <div class="container">
    <p class="section-eyebrow" data-animate>✦ FREE CONSULTATION</p>
    <h1 class="section-title text-gold" style="font-size:var(--text-3xl);" data-animate data-animate-delay="1">
      Confused? Talk to an Expert — Free.
    </h1>
    <p class="section-subtitle" style="color:rgba(245,240,232,0.8);max-width:560px;margin-inline:auto;margin-bottom:var(--space-8);" data-animate data-animate-delay="2">
      Our qualified Ayurvedic Vaidyas understand your body type, your concerns, and your lifestyle — and recommend only what's right for you.
    </p>
    <div style="display:flex;justify-content:center;gap:var(--space-4);flex-wrap:wrap;" data-animate data-animate-delay="3">
      <a href="https://wa.me/919876543210?text=Namaste!+I'd+like+a+free+Ayurvedic+consultation."
         target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
        Chat on WhatsApp
      </a>
      <a href="tel:+919876543210" class="btn btn-ghost-light btn-lg">📞 Call Us Free</a>
    </div>
  </div>
</section>

<!-- How It Works -->
<section class="section section-parchment">
  <div class="container">
    <div class="section-header" data-animate>
      <p class="section-eyebrow">✦ THE PROCESS</p>
      <h2 class="section-title">How It Works</h2>
    </div>
    <div class="steps-grid" style="max-width:700px;margin-inline:auto;">
      <div class="step" data-animate data-animate-delay="1">
        <div class="step__icon-wrap"><span class="step__icon">💬</span><span class="step__number">1</span></div>
        <h3 class="step__title" style="color:var(--color-primary);">Chat</h3>
        <p class="step__desc" style="color:var(--color-text-secondary);">Tell us your concern on WhatsApp or call. No forms, no wait time.</p>
      </div>
      <div class="step" data-animate data-animate-delay="2">
        <div class="step__icon-wrap"><span class="step__icon">🩺</span><span class="step__number">2</span></div>
        <h3 class="step__title" style="color:var(--color-primary);">Diagnose</h3>
        <p class="step__desc" style="color:var(--color-text-secondary);">Our Vaidya asks about your Prakriti, lifestyle, and symptoms.</p>
      </div>
      <div class="step" data-animate data-animate-delay="3">
        <div class="step__icon-wrap"><span class="step__icon">🌿</span><span class="step__number">3</span></div>
        <h3 class="step__title" style="color:var(--color-primary);">Recommend</h3>
        <p class="step__desc" style="color:var(--color-text-secondary);">Get a personalised formula recommendation. No pressure to buy.</p>
      </div>
    </div>
  </div>
</section>

<!-- Meet the Vaidyas -->
<section class="section">
  <div class="container">
    <div class="section-header" data-animate>
      <p class="section-eyebrow">✦ OUR EXPERTS</p>
      <h2 class="section-title">Meet Our Vaidyas</h2>
    </div>
    <div class="vaidyas-grid">
      {%- assign vaidyas = "Dr. Priya Sharma,Dr. Ramesh Iyer,Dr. Sunita Joshi,Dr. Arjun Nair" | split: "," -%}
      {%- assign specs = "Hair & Scalp Health|Skin Science & Kumkumadi|Women's Wellness & PCOS|Joint Health & Immunity" | split: "|" -%}
      {%- assign quals = "BAMS, MD Ayurveda|BAMS, PG Dermatology|BAMS, MD Streeroga|BAMS, MD Panchakarma" | split: "|" -%}
      {%- for vaidya in vaidyas -%}
        <div class="vaidya-card" data-animate data-animate-delay="{{ forloop.index }}">
          <div class="vaidya-card__avatar" aria-hidden="true">{{ vaidya | slice: 3, 1 }}</div>
          <h3 class="vaidya-card__name">{{ vaidya }}</h3>
          <p class="vaidya-card__qual">{{ quals[forloop.index0] }}</p>
          <p class="vaidya-card__spec">Specialises in: {{ specs[forloop.index0] }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<!-- Consultation Form -->
<section class="section section-herb">
  <div class="container">
    <div class="consult-form-wrap" data-animate>
      <h2 class="section-title" style="text-align:center;color:var(--color-primary);">Book a Consultation</h2>
      <p class="section-subtitle">We'll get back to you within 2 hours on business days.</p>
      <form class="consult-form" action="/contact" method="post" accept-charset="UTF-8">
        <input type="hidden" name="form_type" value="contact">
        <input type="hidden" name="utf8" value="✓">
        <div class="consult-form__grid">
          <div class="form-group">
            <label for="cf-name">Full Name</label>
            <input type="text" id="cf-name" name="contact[name]" required placeholder="Your name">
          </div>
          <div class="form-group">
            <label for="cf-phone">Mobile Number</label>
            <input type="tel" id="cf-phone" name="contact[phone]" required placeholder="+91 XXXXX XXXXX">
          </div>
          <div class="form-group">
            <label for="cf-concern">Main Concern</label>
            <select id="cf-concern" name="contact[concern]" required>
              <option value="">Select your concern</option>
              <option>Hair Fall</option>
              <option>Dandruff / Scalp Issues</option>
              <option>Skin Problems</option>
              <option>Joint Pain / Arthritis</option>
              <option>Digestive Issues</option>
              <option>Immunity / General Wellness</option>
              <option>PCOS / Women's Wellness</option>
              <option>Diabetes Support</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="cf-time">Preferred Time</label>
            <select id="cf-time" name="contact[preferred_time]">
              <option>Morning (10am–1pm)</option>
              <option>Afternoon (1pm–4pm)</option>
              <option>Evening (4pm–7pm)</option>
            </select>
          </div>
          <div class="form-group">
            <label for="cf-lang">Preferred Language</label>
            <select id="cf-lang" name="contact[language]">
              <option>Hindi</option>
              <option>English</option>
              <option>Hinglish (Hindi + English)</option>
            </select>
          </div>
        </div>
        <button type="submit" class="btn btn-primary btn-lg" style="width:100%;margin-top:var(--space-6);">
          Book Free Consultation
        </button>
      </form>
    </div>
  </div>
</section>

<style>
.vaidyas-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-6);
}
@media (min-width: 768px) { .vaidyas-grid { grid-template-columns: repeat(4, 1fr); } }
.vaidya-card {
  text-align: center;
  padding: var(--space-6);
  background: var(--color-bg-secondary);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border-light);
}
.vaidya-card__avatar {
  width: 80px; height: 80px;
  background: var(--color-bg-herb);
  border-radius: 50%;
  margin-inline: auto;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-heading);
  font-size: var(--text-2xl);
  color: var(--color-primary);
  border: 2px solid var(--color-border-light);
  margin-bottom: var(--space-4);
}
.vaidya-card__name { font-family: var(--font-heading); font-size: var(--text-base); color: var(--color-primary); margin-bottom: var(--space-1); }
.vaidya-card__qual { font-size: var(--text-xs); color: var(--color-text-secondary); font-family: var(--font-label); font-weight: 600; margin-bottom: var(--space-2); }
.vaidya-card__spec { font-size: var(--text-xs); color: var(--color-secondary); font-style: italic; }
.consult-form-wrap { max-width: 700px; margin-inline: auto; }
.consult-form__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-top: var(--space-8); }
@media (min-width: 640px) { .consult-form__grid { grid-template-columns: repeat(2, 1fr); } }
.form-group { display: flex; flex-direction: column; gap: var(--space-2); }
.form-group label { font-family: var(--font-label); font-size: var(--text-sm); font-weight: 600; color: var(--color-text-secondary); }
.form-group input,
.form-group select {
  padding: var(--space-3) var(--space-4);
  border: 2px solid var(--color-border);
  border-radius: var(--radius-lg);
  font-family: var(--font-body);
  font-size: var(--text-base);
  background: var(--color-bg-primary);
  color: var(--color-text-primary);
  transition: border-color var(--transition-fast);
  width: 100%;
}
.form-group input:focus,
.form-group select:focus { outline: none; border-color: var(--color-accent-gold); }
</style>
