{{ 'section-products.css' | asset_url | stylesheet_tag }}
{{ 'kayakalp-filters.js' | asset_url | script_tag }}

<div class="collection-page section">
  <div class="container">

    <!-- Collection Header -->
    <header class="collection-header" data-animate>
      {%- if collection.image -%}
        <div class="collection-header__image">
          <img
            src="{{ collection.image | img_url: '1400x400', crop: 'center' }}"
            alt="{{ collection.title | escape }}"
            loading="lazy"
            width="1400" height="400">
          <div class="collection-header__overlay"></div>
          <div class="collection-header__content">
            <p class="section-eyebrow">✦ COLLECTION</p>
            <h1>{{ collection.title }}</h1>
            {%- if collection.description != blank -%}
              <p class="collection-header__desc">{{ collection.description | strip_html | truncate: 200 }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- else -%}
        <div class="collection-header__text">
          <p class="section-eyebrow">✦ COLLECTION</p>
          <h1 class="section-title">{{ collection.title }}</h1>
          {%- if collection.description != blank -%}
            <p class="section-subtitle">{{ collection.description | strip_html | truncate: 200 }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    </header>

    <!-- Toolbar: Count + Sort -->
    <div class="collection-toolbar">
      <p class="collection-toolbar__count">
        {{ collection.all_products_count }} products
      </p>
      <div class="collection-toolbar__sort">
        <label for="sort-select" class="sr-only">Sort by</label>
        <select
          id="sort-select"
          class="collection-sort js-collection-sort"
          aria-label="Sort products">
          <option value="manual" {% if collection.sort_by == 'manual' %}selected{% endif %}>Bestselling</option>
          <option value="price-ascending" {% if collection.sort_by == 'price-ascending' %}selected{% endif %}>Price: Low–High</option>
          <option value="price-descending" {% if collection.sort_by == 'price-descending' %}selected{% endif %}>Price: High–Low</option>
          <option value="created-descending" {% if collection.sort_by == 'created-descending' %}selected{% endif %}>Newest</option>
          <option value="best-selling" {% if collection.sort_by == 'best-selling' %}selected{% endif %}>Best Selling</option>
        </select>
      </div>
    </div>

    <!-- Product Grid -->
    {%- if collection.products.size > 0 -%}
      <div class="featured-products__grid" id="collection-grid" role="list">
        {%- for product in collection.products -%}
          <div role="listitem" data-animate data-animate-delay="{{ forloop.index | modulo: 4 | plus: 1 }}">
            {% render 'product-card', product: product, lazy: true %}
          </div>
        {%- endfor -%}
      </div>

      <!-- Pagination -->
      {%- if paginate.pages > 1 -%}
        <div class="pagination" role="navigation" aria-label="Pagination">
          {{- paginate | default_pagination -}}
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="collection-empty">
        <p class="collection-empty__icon">🌿</p>
        <h2>No products found</h2>
        <p>Try adjusting your filters or browse our <a href="/collections/all">full catalogue</a>.</p>
      </div>
    {%- endif -%}

  </div>
</div>

<style>
.collection-header__image {
  position: relative;
  border-radius: var(--radius-xl);
  overflow: hidden;
  margin-bottom: var(--space-10);
  height: 280px;
}
@media (min-width: 768px) { .collection-header__image { height: 360px; } }
.collection-header__image img { width: 100%; height: 100%; object-fit: cover; }
.collection-header__overlay { position: absolute; inset: 0; background: rgba(28, 46, 20, 0.55); }
.collection-header__content {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: var(--space-8);
  color: var(--color-text-light);
}
.collection-header__content h1 { font-family: var(--font-heading); font-size: var(--text-2xl); color: var(--color-text-gold); }
@media (min-width: 768px) { .collection-header__content h1 { font-size: var(--text-3xl); } }
.collection-header__desc { font-size: var(--text-sm); opacity: 0.8; max-width: 500px; }
.collection-header__text { text-align: center; margin-bottom: var(--space-10); }
.collection-toolbar {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: var(--space-8);
  padding: var(--space-4) 0;
  border-bottom: 1px solid var(--color-border-light);
}
.collection-toolbar__count { font-family: var(--font-label); font-size: var(--text-sm); color: var(--color-text-secondary); }
.collection-sort {
  font-family: var(--font-label); font-size: var(--text-sm);
  border: 1px solid var(--color-border); border-radius: var(--radius-pill);
  padding: var(--space-2) var(--space-4);
  background: var(--color-bg-primary);
  color: var(--color-text-primary);
  cursor: pointer;
}
.collection-sort:focus { outline: 2px solid var(--color-accent-gold); }
.collection-empty { text-align: center; padding: var(--space-20) 0; }
.collection-empty__icon { font-size: 4rem; opacity: 0.4; }
.collection-empty h2 { font-family: var(--font-heading); font-size: var(--text-xl); margin: var(--space-4) 0; }
.pagination { display: flex; justify-content: center; gap: var(--space-2); margin-top: var(--space-12); }
.pagination a, .pagination span {
  width: 40px; height: 40px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%; font-family: var(--font-label); font-size: var(--text-sm);
  border: 1px solid var(--color-border); transition: all var(--transition-fast);
}
.pagination a:hover, .pagination .current {
  background: var(--color-primary); color: #fff; border-color: var(--color-primary);
}
</style>
